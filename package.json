{
	"name": "@azure-net/edges",
	"version": "1.1.5",
	"license": "MIT",
	"author": "Pixel1917",
	"description": "A blazing-fast, extremely lightweight and SSR-friendly store for Svelte",
	"homepage": "https://github.com/Pixel1917/edge-s",
	"bugs": {
		"url": "https://github.com/Pixel1917/edge-s/issues",
		"email": "sank195951@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Pixel1917/edge-s.git"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "husky && svelte-kit sync",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"precommit": "pnpm format",
		"commit": "pnpm format && git add . && git-cz && git push"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server/index.d.ts",
			"svelte": "./dist/server/index.js"
		},
		"./context": {
			"types": "./dist/context/index.d.ts",
			"svelte": "./dist/context/index.js"
		},
		"./state": {
			"types": "./dist/store/index.d.ts",
			"svelte": "./dist/store/index.js"
		},
		"./plugin": {
			"types": "./dist/plugin/index.d.ts",
			"import": "./dist/plugin/index.js",
			"default": "./dist/plugin/index.js"
		},
		"./dev": {
			"types": "./dist/utils/dev.d.ts",
			"default": "./dist/utils/dev.js"
		},
		"./dev-component": {
			"types": "./dist/utils/DevTools.svelte.d.ts",
			"default": "./dist/utils/DevTools.svelte"
		}
	},
	"peerDependencies": {
		"@sveltejs/kit": ">=2.0.0",
		"svelte": ">=5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"commitizen": "^4.3.1",
		"env-cmd": "^11.0.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"git-cz": "^4.9.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.53.5",
		"svelte-check": "^4.4.6",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.5",
		"vitest": "^4.1.4"
	},
	"config": {
		"commitizen": {
			"path": "git-cz"
		}
	},
	"keywords": [
		"sveltekit",
		"svelte",
		"store",
		"state",
		"edge-s",
		"ssr state",
		"state management",
		"ssr store"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"packageManager": "pnpm@9.13.2+sha512.88c9c3864450350e65a33587ab801acf946d7c814ed1134da4a924f6df5a2120fd36b46aab68f7cd1d413149112d53c7db3a4136624cfd00ff1846a0c6cef48a",
	"dependencies": {
		"@azure-net/tools": "^1.1.5"
	}
}
